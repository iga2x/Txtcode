# Hello World in Txt-code
# The simplest possible Txt-code program

print → "Hello, World!"

# Variables
store → name → "Alice"
print → "Hello, " + name

# Functions
define → greet → (name)
  return → "Hello, " + name
end

print → greet("World")

# Control flow
store → age → 25

if → age > 18
  print → "Adult"
else
  print → "Minor"
end
