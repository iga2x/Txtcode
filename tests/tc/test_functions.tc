## Function tests — define, call, return, higher-order, recursion

# ── Basic functions ───────────────────────────────────────────────────────────

define → add → (a, b)
  return → a + b
end

define → multiply → (a, b)
  return → a * b
end

assert(add(2, 3) == 5, "add")
assert(multiply(4, 5) == 20, "multiply")
assert(add(0, 0) == 0, "add zeros")

# ── Max/min using store pattern (avoids early-return runtime issues) ───────────

define → max_val → (a, b)
  store → result → b
  if → a > b
    store → result → a
  end
  return → result
end

define → min_val → (a, b)
  store → result → b
  if → a < b
    store → result → a
  end
  return → result
end

assert(max_val(5, 3) == 5, "max first")
assert(max_val(2, 9) == 9, "max second")
assert(max_val(4, 4) == 4, "max equal")
assert(min_val(5, 3) == 3, "min second")
assert(min_val(2, 9) == 2, "min first")

# ── Iterative factorial ───────────────────────────────────────────────────────

define → factorial → (n)
  store → acc → 1
  store → i → 2
  while → i <= n
    store → acc → acc * i
    store → i → i + 1
  end
  return → acc
end

assert(factorial(0) == 1, "factorial 0")
assert(factorial(1) == 1, "factorial 1")
assert(factorial(5) == 120, "factorial 5")
assert(factorial(7) == 5040, "factorial 7")

# ── Nested function definitions ───────────────────────────────────────────────

define → sum_of_squares → (n)
  define → square → (x)
    return → x * x
  end
  store → total → 0
  store → i → 1
  while → i <= n
    store → total → total + square(i)
    store → i → i + 1
  end
  return → total
end

assert(sum_of_squares(3) == 14, "1^2+2^2+3^2=14")
assert(sum_of_squares(4) == 30, "1+4+9+16=30")

# ── Composition ───────────────────────────────────────────────────────────────

define → compose_add_mul → (a, b, c)
  return → multiply(add(a, b), c)
end

assert(compose_add_mul(2, 3, 4) == 20, "(2+3)*4=20")

print → "functions: all tests passed"
