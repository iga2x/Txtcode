{
  "Variable assignment": {
    "prefix": "store",
    "body": ["store → ${1:name} → ${2:value}"],
    "description": "Assign a value to a variable"
  },
  "Typed variable assignment": {
    "prefix": "storet",
    "body": ["store → ${1:name}: ${2:int} → ${3:value}"],
    "description": "Assign a typed variable"
  },
  "Function definition": {
    "prefix": "define",
    "body": [
      "define → ${1:name} → (${2:params})",
      "  ${3:body}",
      "end"
    ],
    "description": "Define a function"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if → ${1:condition}",
      "  ${2:body}",
      "end"
    ],
    "description": "If statement"
  },
  "If-else statement": {
    "prefix": "ifelse",
    "body": [
      "if → ${1:condition}",
      "  ${2:true_body}",
      "else",
      "  ${3:false_body}",
      "end"
    ],
    "description": "If-else statement"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for → ${1:item} in ${2:collection}",
      "  ${3:body}",
      "end"
    ],
    "description": "For loop"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while → ${1:condition}",
      "  ${2:body}",
      "end"
    ],
    "description": "While loop"
  },
  "Try-catch": {
    "prefix": "try",
    "body": [
      "try",
      "  ${1:body}",
      "catch ${2:err}",
      "  ${3:handler}",
      "end"
    ],
    "description": "Try-catch error handling"
  },
  "Struct definition": {
    "prefix": "struct",
    "body": ["struct ${1:Name}(${2:field}: ${3:type})"],
    "description": "Define a struct"
  },
  "Match statement": {
    "prefix": "match",
    "body": [
      "match → ${1:value}",
      "  case ${2:pattern} → ${3:result}",
      "  case _ → ${4:default}",
      "end"
    ],
    "description": "Pattern match"
  },
  "Lambda expression": {
    "prefix": "lambda",
    "body": ["(${1:x}) → ${2:x * 2}"],
    "description": "Lambda expression"
  },
  "Return statement": {
    "prefix": "return",
    "body": ["return → ${1:value}"],
    "description": "Return a value"
  },
  "Print line": {
    "prefix": "println",
    "body": ["println(${1:value})"],
    "description": "Print a value with newline"
  },
  "Async run": {
    "prefix": "async",
    "body": [
      "store → ${1:handle} → async_run(${2:func})",
      "store → ${3:result} → await_future(${1:handle})"
    ],
    "description": "Async function execution pattern"
  },
  "Import module": {
    "prefix": "import",
    "body": ["import → \"${1:module_name}\""],
    "description": "Import a module"
  },
  "Type alias": {
    "prefix": "type",
    "body": ["type → ${1:Name} → ${2:int}"],
    "description": "Define a type alias"
  }
}
