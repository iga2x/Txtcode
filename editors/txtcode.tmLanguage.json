{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Txtcode",
  "scopeName": "source.txtcode",
  "fileTypes": ["tc"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#type-annotation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.txtcode",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.txtcode",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.txtcode",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "string.quoted.double.raw.txtcode",
          "begin": "r\"",
          "end": "\"",
          "patterns": []
        },
        {
          "name": "string.quoted.double.interpolated.txtcode",
          "begin": "f\"",
          "end": "\"",
          "patterns": [
            {
              "name": "meta.embedded.line.txtcode",
              "begin": "(?<!\\\\)\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            },
            { "include": "#string-escape" }
          ]
        },
        {
          "name": "string.quoted.double.txtcode",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "include": "#string-escape" }]
        }
      ]
    },
    "string-escape": {
      "name": "constant.character.escape.txtcode",
      "match": "\\\\[nrt\\\\\"'{]"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.txtcode",
          "match": "\\b(if|else|elseif|for|while|break|continue|return|end|try|catch|match|in)\\b"
        },
        {
          "name": "keyword.declaration.txtcode",
          "match": "\\b(store|define|struct|type|error|import)\\b"
        },
        {
          "name": "keyword.operator.logical.txtcode",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.txtcode",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.txtcode",
          "match": "\\bnull\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.txtcode",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.txtcode",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.float.txtcode",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.txtcode",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.txtcode",
          "match": "→"
        },
        {
          "name": "keyword.operator.pipe.txtcode",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.optional-chain.txtcode",
          "match": "\\?\\.|\\?\\[|\\?\\("
        },
        {
          "name": "keyword.operator.ternary.txtcode",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.assignment.compound.txtcode",
          "match": "[+\\-*/%]="
        },
        {
          "name": "keyword.operator.comparison.txtcode",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.range.txtcode",
          "match": "\\.\\."
        }
      ]
    },
    "function-def": {
      "match": "\\b(define)\\s*→\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*→",
      "captures": {
        "1": { "name": "keyword.declaration.txtcode" },
        "2": { "name": "entity.name.function.txtcode" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "entity.name.function.txtcode" }
      }
    },
    "type-annotation": {
      "match": ":\\s*(int|float|string|bool|array|map|null|any)\\b",
      "captures": {
        "1": { "name": "support.type.txtcode" }
      }
    }
  }
}
