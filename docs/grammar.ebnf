(* Txtcode / NPL Formal Grammar — EBNF *)
(* Version: 3.0.0 — corrected 2026-03-21 *)
(* Notation: { x } = zero or more x    *)
(*           [ x ] = optional x         *)
(*           x | y = alternative        *)

(* ────────────────────────────────────────────────────────────────────── *)
(* TOP-LEVEL                                                              *)
(* ────────────────────────────────────────────────────────────────────── *)

program        = { statement } ;

statement      = assignment
               | compound_assign              (* G3: was missing from statement *)
               | const_decl
               | function_def
               | struct_def
               | enum_def
               | protocol_def
               | type_alias
               | named_error
               | if_stmt
               | for_stmt
               | while_stmt
               | return_stmt
               | yield_stmt
               | match_stmt
               | try_catch
               | import_stmt
               | export_stmt
               | expression_stmt
               ;

(* ────────────────────────────────────────────────────────────────────── *)
(* DECLARATIONS                                                           *)
(* ────────────────────────────────────────────────────────────────────── *)

assignment     = "store" "→" lvalue [ ":" type_expr ] "→" expression ;
const_decl     = "const" "→" identifier [ ":" type_expr ] "→" expression ;
lvalue         = identifier
               | identifier "[" expression "]"    (* index assign *)
               ;

(* G2: function_def now also accepts dotted method name Type.method *)
function_def   = "define" "→" ( identifier | identifier "." identifier ) "→"
                   [ "<" type_param_list ">" ]
                   "(" [ param_list ] ")" [ "→" type_expr ] NEWLINE
                   { statement }
                 "end" ;

type_param_list = type_param { "," type_param } ;
type_param      = identifier [ ":" identifier ]   (* T or T: Constraint *) ;

param_list     = param { "," param } ;
param          = identifier [ ":" type_expr ] ;

(* G1: implements uses optional arrow "→", not colon *)
struct_def     = "struct" identifier
                   [ "<" type_param_list ">" ]
                   "(" [ struct_field_list ] ")"
                   [ "implements" [ "→" ] identifier_list ] ;

struct_field_list = struct_field { "," struct_field } ;
struct_field      = identifier ":" type_expr ;

enum_def       = "enum" "→" identifier "→" enum_variants ;
enum_variants  = identifier { "," identifier } ;

protocol_def   = "protocol" identifier NEWLINE
                   { protocol_method }
                 "end" ;
protocol_method = identifier "→" "(" [ param_list ] ")" [ "→" type_expr ] NEWLINE ;

type_alias     = "type" "→" identifier "→" type_expr ;
named_error    = "error" "→" identifier "→" expression ;

(* ────────────────────────────────────────────────────────────────────── *)
(* COMPOUND ASSIGNMENT                                                    *)
(* ────────────────────────────────────────────────────────────────────── *)

(* G3: listed in statement above; defined here *)
compound_assign = lvalue ( "+=" | "-=" | "*=" | "/=" | "%=" | "**=" ) expression ;

(* ────────────────────────────────────────────────────────────────────── *)
(* CONTROL FLOW                                                           *)
(* ────────────────────────────────────────────────────────────────────── *)

if_stmt        = "if" "→" expression NEWLINE
                   { statement }
                 { "elseif" "→" expression NEWLINE { statement } }
                 [ "else" NEWLINE { statement } ]
                 "end" ;

for_stmt       = "for" "→" identifier "in" expression NEWLINE
                   { statement }
                 "end" ;

while_stmt     = "while" "→" expression NEWLINE
                   { statement }
                 "end" ;

return_stmt    = "return" "→" expression ;
yield_stmt     = "yield" "→" expression ;

match_stmt     = "match" expression NEWLINE
                   { match_case }
                 "end" ;

match_case     = "case" pattern NEWLINE { statement } ;

pattern        = literal_pattern
               | identifier                        (* variable bind or enum variant *)
               | identifier "(" identifier ")"     (* constructor with payload *)
               | identifier "." identifier         (* qualified enum variant *)
               | "[" pattern_list "]"              (* array destructure *)
               | "{" field_pattern_list "}"        (* struct destructure *)
               | "_"                               (* wildcard *)
               | pattern "if" expression           (* guard *)
               ;

literal_pattern = integer | float | string | "true" | "false" | "null" ;

(* G6: correct notation — each element separated by comma, rest at end *)
pattern_list   = pattern { "," pattern } [ "," "..." identifier ] ;

field_pattern_list = identifier { "," identifier } ;   (* {x, y} *)

try_catch      = "try" NEWLINE
                   { statement }
                 "catch" identifier NEWLINE
                   { statement }
                 "end" ;

(* ────────────────────────────────────────────────────────────────────── *)
(* MODULES                                                                *)
(* ────────────────────────────────────────────────────────────────────── *)

(* G5: "→" after import/from is optional; "from" clause is optional *)
import_stmt    = "import" [ "→" ] identifier_list
                   [ "from" [ "→" ] ( string | identifier ) ]
                   [ "as" [ "→" ] identifier ]
               | "import" "*" "from" [ "→" ] string [ "as" [ "→" ] identifier ]
               ;

export_stmt    = "export" [ "→" ] identifier_list ;

identifier_list = identifier { "," identifier } ;

(* ────────────────────────────────────────────────────────────────────── *)
(* EXPRESSIONS                                                            *)
(* ────────────────────────────────────────────────────────────────────── *)

expression_stmt = expression ;

expression     = ternary ;

ternary        = pipeline [ "?" expression ":" expression ] ;

pipeline       = or_expr { "|>" or_expr } ;

or_expr        = and_expr { "or" and_expr } ;
and_expr       = not_expr { "and" not_expr } ;
not_expr       = [ "not" ] compare_expr ;

compare_expr   = null_coal { ( "==" | "!=" | "<" | "<=" | ">" | ">=" ) null_coal } ;

null_coal      = add_expr { "??" add_expr } ;

add_expr       = mul_expr { ( "+" | "-" ) mul_expr } ;

mul_expr       = unary_expr { ( "*" | "/" | "%" ) unary_expr } ;

unary_expr     = [ "-" | "not" ] power_expr ;

power_expr     = postfix_expr [ "**" unary_expr ] ;

postfix_expr   = primary_expr { postfix_op } ;

postfix_op     = "." identifier                        (* member access *)
               | "." identifier "(" [ arg_list ] ")"   (* method call *)
               | "[" expression "]"                    (* index *)
               | "[" [ expression ] ":" [ expression ] [ ":" [ expression ] ] "]"
                                                        (* G8: slice — single colon, Python-style *)
               | "(" [ arg_list ] ")"                  (* call *)
               | "?." identifier                       (* optional member — "?." is one token *)
               | "?" "[" expression "]"                (* G4: optional index — "?" and "[" are separate tokens *)
               | "?." "(" [ arg_list ] ")"             (* G9: optional call — obj?.(args) *)
               ;

primary_expr   = literal
               | identifier
               | lambda_expr
               | array_literal
               | map_literal                           (* {key: val, ...} — has colon after first element *)
               | set_literal                           (* {val, val, ...} — no colon; same brace, different content *)
               | struct_literal                        (* Identifier{field: val, ...} — identifier before brace *)
               | "(" expression ")"
               | function_call
               ;

function_call  = identifier "(" [ arg_list ] ")" ;

arg_list       = expression { "," expression } ;

lambda_expr    = "(" [ param_list ] ")" "→" expression ;

array_literal  = "[" [ expression { "," expression } ] "]" ;

map_literal    = "{" map_pair { "," map_pair } "}" ;
map_pair       = expression ":" expression ;

(* G7: no "set" keyword prefix — bare braces, disambiguated from map by absence of ":" *)
set_literal    = "{" expression { "," expression } "}" ;

struct_literal    = identifier "{" [ struct_init_field { "," struct_init_field } ] "}" ;
struct_init_field = identifier ":" expression ;

(* ────────────────────────────────────────────────────────────────────── *)
(* TYPE EXPRESSIONS                                                       *)
(* ────────────────────────────────────────────────────────────────────── *)

type_expr      = primitive_type
               | "array" "[" type_expr "]"
               | "map" "[" type_expr "]"
               | "set" "[" type_expr "]"
               | type_expr "?"                    (* nullable *)
               | "Future" "<" type_expr ">"
               | identifier                       (* user-defined / generic *)
               | "(" type_param_list ")" "→" type_expr   (* function type *)
               ;

primitive_type = "int" | "float" | "string" | "char" | "bool" | "null" ;

(* ────────────────────────────────────────────────────────────────────── *)
(* LITERALS                                                               *)
(* ────────────────────────────────────────────────────────────────────── *)

literal        = integer | float | string | char | boolean | "null" ;

integer        = [ "-" ] digit { digit | "_" }   (* 1_000_000 separators OK *) ;
float          = integer "." { digit } ;
string         = '"' { str_char } '"'
               | "f" '"' { interpolated_char | "{" expression "}" } '"'  (* f-string *)
               | 'r' '"' { raw_char } '"'                                (* raw string *)
               | '"""' { any_char } '"""'                                 (* multiline *)
               ;
char           = "'" any_char "'" ;
boolean        = "true" | "false" ;

digit          = "0" | … | "9" ;
identifier     = letter { letter | digit | "_" } ;
letter         = "a" | … | "z" | "A" | … | "Z" | "_" ;

(* ────────────────────────────────────────────────────────────────────── *)
(* NOTES                                                                  *)
(* ────────────────────────────────────────────────────────────────────── *)

(* 1. "→" is the ASCII sequence "->" or the Unicode character U+2192.      *)
(* 2. NEWLINE = "\n" or "\r\n"; indentation is whitespace-only.            *)
(* 3. Comments: single-line "#" ... NEWLINE;                               *)
(*              doc-comment "##" ... NEWLINE (extracted by docgen).        *)
(* 4. Operator precedence (low → high):                                    *)
(*      ternary → pipeline → or → and → not → compare → ?? →             *)
(*      + - → * / % → unary - / not → ** → postfix → primary              *)
(* 5. "store → arr[0] → val" is index-assignment (separate production).   *)
(* 6. Lambda parameter types are optional (Type::Unknown if absent).       *)
(* 7. "match" may match on any expression; exhaustiveness is checked       *)
(*    statically only when the type is a known enum (Type::Identifier).    *)
(* 8. map vs set vs struct disambiguation at "{":                          *)
(*      - Identifier immediately before "{" → struct_literal               *)
(*      - "{" expr ":" ... "}" → map_literal                               *)
(*      - "{" expr "," ... "}" → set_literal   (no colon after first elem) *)
(*      - "{" "}" → empty map_literal                                      *)
(* 9. "?." is a single OptionalChain lexer token.                          *)
(*    "?" followed by "[" is two separate tokens (parsed via lookahead).   *)
(* 10. Slice uses single colon: arr[1:3], arr[::2], arr[1:end].           *)
(*     The keyword "end" may appear as the end bound (meaning last index). *)
